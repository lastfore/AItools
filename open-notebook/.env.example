# Open Notebook Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# REQUIRED
# =============================================================================

# Encryption key for storing API credentials securely in the database
# Change this to any secret string (minimum 16 characters recommended)
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-secret-string

# =============================================================================
# DATABASE (Default values work with docker-compose.yml)
# =============================================================================
# In Docker Compose, the DB hostname is "surrealdb". If you run the API on your
# machine with `uv run` / uvicorn, use: SURREAL_URL=ws://localhost:8000/rpc

SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

# If you use a system or corporate HTTP proxy, allow direct access to local SurrealDB
# and Speaches (otherwise localhost health checks and TTS/STT calls can fail).
NO_PROXY=127.0.0.1,localhost,127.0.0.1:8000,localhost:8000,127.0.0.1:8969,localhost:8969

# =============================================================================
# OPTIONAL: Local Speaches + SiliconFlow (configure via UI — Settings → API Keys)
# =============================================================================
# Speaches (local, started by start-dev.ps1):
#   OpenAI Compatible → Base URL: http://127.0.0.1:8969/v1
#   TTS model: speaches-ai/Kokoro-82M-v1.0-ONNX (Chinese voices: zf_xiaoxiao, zm_yunxi)
#   STT model: Systran/faster-whisper-large-v3
#
# SiliconFlow (cloud backup):
#   OpenAI Compatible → Base URL: https://api.siliconflow.cn/v1
#   TTS: fnlp/MOSS-TTSD-v0.5 or FunAudioLLM/CosyVoice2-0.5B
#   STT: FunAudioLLM/SenseVoiceSmall

# =============================================================================
# OPTIONAL: AI Provider API Keys
# =============================================================================
# You can configure these via the UI (Settings → API Keys) or set them here
# UI configuration is recommended for better security and flexibility

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI
# GOOGLE_API_KEY=...

# Groq
# GROQ_API_KEY=gsk_...

# =============================================================================
# OPTIONAL: Advanced Configuration
# =============================================================================

# External API URL (for webhooks, callbacks, etc.)
# API_URL=http://localhost:5055

# Ollama endpoint (if running locally)
# OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# OPTIONAL: SearXNG (internet keyword search → URLs, then add as link sources)
# =============================================================================
# Run SearXNG via Docker (see examples/docker-compose-searxng.yml and docs/1-INSTALLATION/docker-compose.md).
# Windows dev: start-dev.ps1 starts the searxng container when SEARXNG_ENABLED=true.
# SEARXNG_ENABLED=false
# SEARXNG_BASE_URL=http://localhost:8080
# SEARXNG_TIMEOUT_SECONDS=20
# SEARXNG_MAX_RESULTS=30
# SEARXNG_BLOCKED_DOMAINS=pinterest.com,facebook.com
# SEARXNG_ALLOWED_DOMAINS=
# SEARXNG_DEFAULT_LLM_RANKING=false
# SEARXNG_LLM_RELEVANCE_THRESHOLD=0.45
#
# Dotenv note: comment lines must use "# " (hash + space). "#KEY=value" is still parsed as a variable.
# SearXNG container config: repo searxng/settings.yml must set server.secret_key (see file in repo).

# Content processing
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=150

# Embedding batch size (default 50). Use 10 for DashScope text-embedding-v4; 8 for CPU-only local embedding.
# OPEN_NOTEBOOK_EMBEDDING_BATCH_SIZE=10

# Security
# BASIC_AUTH_USERNAME=admin
# BASIC_AUTH_PASSWORD=secret

# For more configuration options, see:
# https://github.com/lfnovo/open-notebook/blob/main/docs/5-CONFIGURATION/environment-reference.md
